    `partner_usr`     VARCHAR(200) COMMENT 'MISA: app_id, vnpt_username',
    `partner_pwd`     VARCHAR(200) COMMENT 'vnpt_password',
    
    `status`          TINYINT(1) DEFAULT 0 COMMENT '0: Chưa tích hợp; 1: Tích hợp thành công; 8: đã hủy tích hợp',
