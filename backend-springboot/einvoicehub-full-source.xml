    `integration_url` VARCHAR(200) COMMENT 'Override URL riêng cho VNPT',
    `tax_code`        VARCHAR(200) COMMENT 'Mã số thuế',
    
    -- Các trường bổ sung từ project (không có trong bản công ty)
