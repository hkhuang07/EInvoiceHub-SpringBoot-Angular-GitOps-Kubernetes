      targetPort: 6379
      protocol: TCP
  selector:
    app: redis
    tier: cache

---
apiVersion: v1
kind: Service
metadata:
  name: einvoicehub-prometheus
  namespace: einvoice-dev
  labels:
    app: einvoicehub
    tier: monitoring
  annotations:
    description: "Prometheus Metrics Service"
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 9090
      targetPort: 9090
      protocol: TCP
  selector:
    app: prometheus
    tier: monitoring

---
apiVersion: v1
kind: Service
